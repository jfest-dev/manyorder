# ManyOrder API — copy to .env and fill with REAL values (never commit .env).
# The previous repo leaked credentials in uploaded archives; those must be
# rotated and must never appear in this repository's history.

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/manyorder
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=change-me

# HMAC secret for JWT signing — minimum 32 bytes. Generate with:
#   openssl rand -base64 48
JWT_SECRET=replace-with-a-random-48-byte-secret
JWT_EXPIRATION_MS=86400000

# Optional: enables the Google sign-in button when set (SPA hides it when blank)
GOOGLE_CLIENT_ID=

# Comma-separated origins allowed by CORS
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:3000
